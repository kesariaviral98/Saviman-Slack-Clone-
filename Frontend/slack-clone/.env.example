# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for all REST + Socket.io requests.
# Leave empty in development — Vite proxy forwards /auth, /workspaces, etc.
# Set to your backend URL in production: https://api.yourdomain.com
VITE_API_URL=

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Must match the GOOGLE_CLIENT_ID in server/.env
VITE_GOOGLE_CLIENT_ID=